{
    "name": "axn/laravel-models-organizer",
    "description": "Organize Laravel models concerns (relations, scopes, attributes) in dedicated traits.",
    "homepage": "https://github.com/AXN-Informatique/laravel-models-organizer",
    "support": {
        "issues": "https://github.com/AXN-Informatique/laravel-models-organizer/issues",
        "source": "https://github.com/AXN-Informatique/laravel-models-organizer"
    },
    "authors": [
        {
            "name": "AXN Informatique",
            "email": "developpement@axn.fr"
        }
    ],
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "laravel/framework": "^12.0 || ^13.0",
        "nikic/php-parser": "^5.7"
    },
    "require-dev": {
        "driftingly/rector-laravel": "^2.3.0",
        "laravel/pint": "^1.29.1",
        "rector/rector": "^2.4.2"
    },
    "autoload": {
        "psr-4": {
            "Axn\\ModelsOrganizer\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Axn\\ModelsOrganizer\\ServiceProvider"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
